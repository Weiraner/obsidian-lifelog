{
  "name": "obsidian-lifelog",
  "version": "0.1.0",
  "description": "Turn plain-text daily logs into structured time-series data and visualizations — a local-first personal data system for Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production && node scripts/sync-demo.mjs",
    "sync:demo": "node scripts/sync-demo.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "parse:journal": "tsx scripts/parse-journal.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "quantified-self",
    "local-first",
    "time-tracking",
    "expense-tracking",
    "llm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
